# ---------- Backend ----------
# Get free key at https://openweathermap.org/api (activation can take up to 2 hours)
OPENWEATHER_API_KEY=your_openweathermap_key_here

# Port for the Express backend
PORT=4000

# SQLite file path (relative to /backend)
DATABASE_PATH=./db/weather.sqlite

# CORS — allow the Next.js frontend origin
FRONTEND_ORIGIN=http://localhost:3000

# YouTube Data API v3 key (kept server-side — never exposed to browser)
# Get at https://console.cloud.google.com -> APIs & Services -> Credentials
# Enable: YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# ---------- Frontend ----------
# Public = safe to expose to the browser. This is the URL of your backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Google Maps Embed API key (free tier, no billing needed for basic embeds)
# Get at https://console.cloud.google.com -> APIs & Services -> Credentials
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_embed_key_here
